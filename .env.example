# ============================================================
#  AetherOS — Environment Variables Template
#  Copy to .env and fill in your values
# ============================================================

# ── Pharos Testnet ──────────────────────────────────────────
PHAROS_RPC_URL=https://atlantic.dplabs-internal.com
PHAROS_CHAIN_ID=688689
PHAROS_EXPLORER=https://pharosscan.xyz

# ── Deployer Wallet ─────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x_your_deployer_private_key

# ── Agent HD Wallet ─────────────────────────────────────────
AGENT_MNEMONIC=your twelve word mnemonic phrase goes here

# ── Deployed Contract Addresses (filled after deploy) ───────
AGENT_REGISTRY_ADDRESS=
REPUTATION_NFT_ADDRESS=
SOCIAL_INTERACTION_ADDRESS=

# ── Pharos Testnet Token Addresses ──────────────────────────
WPHRS_ADDRESS=0x838800b758277CC111B2d48Ab01e5E164f8E9471
USDC_ADDRESS=0xcfC8330f4BCAB529c625D12781b1C19466A9Fc8B
USDT_ADDRESS=0xE7E84B8B4f39C507499c40B4ac199B050e2882d5

# ── MySQL ────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=aetheros_db
DATABASE_URL=mysql://root:your_mysql_password@localhost:3306/aetheros_db

# ── Ollama ───────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral:7b
SKIP_OLLAMA_PULL=true

# ── ML Services ──────────────────────────────────────────────
SENTIMENT_SERVICE_URL=http://localhost:9001
FORECAST_SERVICE_URL=http://localhost:9002
RL_POLICY_SERVICE_URL=http://localhost:9003

# ── Pinata IPFS ──────────────────────────────────────────────
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
PINATA_GATEWAY=https://gateway.pinata.cloud

# ── CoinGecko (optional — free tier works without key) ───────
COINGECKO_API_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=

# ── Orchestrator ─────────────────────────────────────────────
ORCHESTRATOR_PORT=4001
ORCHESTRATOR_API_KEY=change_this_to_a_strong_secret_key

# ── Multi-token trading ──────────────────────────────────────
TRADING_TOKENS=ETH,BTC,SOL,BNB,MATIC,AVAX,PHRS

# ── Agent Cycle Intervals (ms) ───────────────────────────────
TRADING_AGENT_INTERVAL_MS=60000
SOCIAL_AGENT_INTERVAL_MS=900000
GOVERNANCE_AGENT_INTERVAL_MS=3600000
BUDGET_ALLOCATOR_INTERVAL_MS=86400000

# ── Risk Scorer ───────────────────────────────────────────────
MAX_RISK_SCORE=70
MIN_REPUTATION_SCORE=30
MAX_POSITION_PCT=0.05

# ── RL Policy ────────────────────────────────────────────────
RL_MODEL_PATH=./model/ppo_trading.zip

# ── SQLite Cache ─────────────────────────────────────────────
SQLITE_CACHE_PATH=./cache/ml_cache.db
CACHE_TTL_SENTIMENT=300
CACHE_TTL_FORECAST=600
CACHE_TTL_RL=60

# ── Dashboard ────────────────────────────────────────────────
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:4001
NEXT_PUBLIC_PHAROS_EXPLORER=https://pharosscan.xyz
DASHBOARD_PORT=3000

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
